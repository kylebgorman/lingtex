\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{simplex}[v1.0 Linguistic example environments]

\IfFormatAtLeastTF {2020-10-01}{}{%
  \RequirePackage{xparse}%
}

%% ---------------------------------------------------------------------------
%% PART 1: Numbered example environments
%% ---------------------------------------------------------------------------

\newcounter{exampleno}
\setcounter{exampleno}{0}

% unlabeledexample — a numbered example with no label.
\newenvironment{unlabeledexample}%
  {\begin{flushleft}%
   \refstepcounter{exampleno}%
   \noindent(\arabic{exampleno})~~\ignorespaces\noindent\ignorespaces}%
  {\end{flushleft}\ignorespacesafterend}

% shortexample — a numbered example with an optional same-line label.
\NewDocumentEnvironment{shortexample}{O{}}%
  {\begin{flushleft}%
   \refstepcounter{exampleno}%
   \noindent(\arabic{exampleno})~~#1:~~\noindent\ignorespaces}%
  {\end{flushleft}\ignorespacesafterend}

% example — a numbered example with an optional label on its own line.
\NewDocumentEnvironment{example}{O{}}%
  {\begin{flushleft}%
   \refstepcounter{exampleno}%
   \noindent(\arabic{exampleno})~~#1:\vskip .5\baselineskip%
   \noindent\ignorespaces}%
  {\end{flushleft}\ignorespacesafterend}


%% ---------------------------------------------------------------------------
%% PART 2: Interlinear gloss macros
%%         Adapted from covington.sty and gloss.tex (van der Goot, 1991)
%% ---------------------------------------------------------------------------

% utility macros to check if names are free so we don't clobber things
\newcommand\def@iffree[1]{%
  \newcommand#1{}%
  \def#1%
}
\newcommand\gdef@iffree[1]{%
  \newcommand#1{}%
  \gdef#1%
}
% borrow from latex's expl3 programming language
% these create variables globally, but \usepackage{simplex} will almost
% generally do that anyway
\newcommand\newbox@iffree[1]{%
  \UseName{box_new:N} #1%
}
\newcommand\newskip@iffree[1]{%
  \UseName{skip_new:N} #1%
}


% \gll — 2-line interlinear gloss.
\def@iffree\gll%
  {\def\baselinestretch{1}%
   \selectfont%
   \bgroup
   \catcode`\^^M=12
   \twosent
  }

% \glll — 3-line interlinear gloss.
\def@iffree\glll%
  {\def\baselinestretch{1}%
   \selectfont%
   \bgroup
   \catcode`\^^M=12
   \threesent
  }

% \glt — Free translation line. Required to close a gloss block.
\def@iffree\glt{\hskip-\glossglue\unhbox\gline\smallskip\newline\hskip 10em}

% \gln — Like \glt but for use when no translation text follows.
\def@iffree\gln{\hskip-\glossglue\unhbox\gline}

% \glend — Terminates the gloss environment (currently a no-op).
\def@iffree\glend{}

%% Internal box registers

\newbox@iffree\lineone
\newbox@iffree\linetwo
\newbox@iffree\linethree
\newbox@iffree\wordone
\newbox@iffree\wordtwo
\newbox@iffree\wordthree
\newbox@iffree\gline

\newskip@iffree\glossglue
\glossglue = 5pt plus 2pt minus 1pt

\def@iffree\ifnotdone{}
\newif\ifnotdone

% Per-line font hooks. Override to change fonts, e.g.:
%   \let\eachwordone=\textit
% 2-letter font switches should never be used in latex
% they have not been defined in the format for decades
% \rm works only if the class defines it 
% *probably* you want \normalfont here? but I'm not sure.
\let\eachwordone=\normalfont
\let\eachwordtwo=\normalfont
\let\eachwordthree=\normalfont

\def@iffree\lastword#1#2#3%
  {\setbox#2=\vbox{\unvbox#2%
                   \global\setbox#3=\lastbox
                  }%
   \ifvoid#3\global\setbox#3=\hbox{#1\strut{} }\fi
  }

\def@iffree\testdone
  {\ifdim\ht\lineone=0pt
       \ifdim\ht\linetwo=0pt \notdonefalse
       \else\notdonetrue
       \fi
   \else\notdonetrue
   \fi
  }

\begingroup
  \catcode`\^^M=12 \endlinechar=-1 % <--- Add a space and % here
  \gdef@iffree\getwords(#1,#2)#3 #4^^M%
    {\setbox#1=\vbox{\hbox{#2\strut#3 }%
                     \unvbox#1%
                    }%
     \def\more{#4}%
     \ifx\more\empty\let\more=\donewords
     \else\let\more=\getwords
     \fi
     \more(#1,#2)#4^^M%
    }
  \gdef@iffree\donewords(#1,#2)^^M{}%
  \gdef@iffree\twosent#1^^M#2^^M%
    {\getwords(\lineone,\eachwordone)#1 ^^M%
     \getwords(\linetwo,\eachwordtwo)#2 ^^M%
     \loop\lastword{\eachwordone}{\lineone}{\wordone}%
          \lastword{\eachwordtwo}{\linetwo}{\wordtwo}%
          \global\setbox\gline=\hbox{\unhbox\gline
                                     \hskip\glossglue
                                     \vtop{\box\wordone
                                           \nointerlineskip
                                           \box\wordtwo
                                          }%
                                    }%
          \testdone
          \ifnotdone
     \repeat
     \egroup
    }
  \gdef@iffree\threesent#1^^M#2^^M#3^^M%
    {\getwords(\lineone,\eachwordone)#1 ^^M%
     \getwords(\linetwo,\eachwordtwo)#2 ^^M%
     \getwords(\linethree,\eachwordthree)#3 ^^M%
     \loop\lastword{\eachwordone}{\lineone}{\wordone}%
          \lastword{\eachwordtwo}{\linetwo}{\wordtwo}%
          \lastword{\eachwordthree}{\linethree}{\wordthree}%
          \global\setbox\gline=\hbox{\unhbox\gline
                                     \hskip\glossglue
                                     \vtop{\box\wordone
                                           \nointerlineskip
                                           \box\wordtwo
                                           \nointerlineskip
                                           \box\wordthree
                                          }%
                                    }%
          \testdone
          \ifnotdone
     \repeat
     \egroup
    }
\endgroup

\endinput
